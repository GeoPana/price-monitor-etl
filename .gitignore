# Local environment files
.env
.env.*
!.env.example

# Python bytecode and caches
__pycache__/
*.py[cod]
*.pyo
*.pyd
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/

# Virtual environments
.venv/
venv/
env/

# Conda environment directories
.conda/

# Build and packaging artifacts
build/
dist/
*.egg-info/
.eggs/
pip-wheel-metadata/

# IDE and OS files
.idea/
.vscode/
*.swp
*.swo
Thumbs.db
.DS_Store

# Project runtime artifacts
logs/*.log
airflow/logs/**
data/raw/**
data/processed/**
data/exports/**

# Keep directory structure in git
!airflow/logs/.gitkeep
!data/raw/.gitkeep
!data/processed/.gitkeep
!data/exports/.gitkeep
!logs/.gitkeep

# SQLite and local database files
*.db
*.sqlite
*.sqlite3
